{
  "layer": "top",
  "position": "bottom",
  "modules-left": ["group/alimentation", "group/whoami", "hyprland/workspaces"],
  "modules-center": ["hyprland/window"],
  "modules-right": ["tray", "keyboard-state", "group/networking", "group/power", "clock"],

  "group/alimentation": {
    "orientation": "inherit",
    "modules": ["custom/poweroff", "custom/reboot", "custom/logout"]
  },
  "custom/poweroff": {
    "format": "<span size='10pt'>ŌÅ╗</span>",
    "on-click": "poweroff",
    "tooltip-format": "Turn off the computer"
  },
  "custom/reboot": {
    "format": "<span size='10pt'>’ĆĪ</span>",
    "on-click": "reboot",
    "tooltip-format": "Reboot the computer"
  },
  "custom/logout": {
    "format": "<span size='10pt'>’éÉ</span>",
    "on-click": "hyprctl dispatch exit",
    "tooltip-format": "Log out from the session"
  },

  "group/whoami": {
    "orientation": "inherit",
    "modules": ["user", "custom/username"]
  },
  "user": {
    "format": "",
    "interval": 60,
    "height": 16,
    "width": 16,
    "icon": true
  },
  "custom/username": {
    "exec": "whoami",
    "tooltip": false
  },

  "hyprland/window": {
    "max-length": 30,
    "on-click": "swaync-client -t -sw"
  },

  "tray": {
    "spacing": 10
  },

  "keyboard-state": {
    "numlock": true,
    "capslock": true,
    "format": {
      "numlock": "N {icon}",
      "capslock": "C {icon} "
    },
    "format-icons": {
      "locked": "<span size='10pt'>’ĆŻ</span>",
      "unlocked": "<span size='10pt'>’é£</span>"
    }
  },

  "hyprland/language": {
    "format-en": "en"
  },

  "group/networking": {
    "orientation": "inherit",
    "modules": ["wireplumber", "network", "bluetooth"]
  },
  "network": {
    "interface": "wlp4s0",
    "format-wifi": "{icon}",
    "format-ethernet": "{icon}",
    "format-disconnected": "{icon}", //An empty format will hide the module.
    "format-icons": {
      "wifi": [
        "<span size='10pt'>¾░ż»</span>",
        "<span size='10pt'>¾░ż¤</span>",
        "<span size='10pt'>¾░żó</span>",
        "<span size='10pt'>¾░żź</span>",
        "<span size='10pt'>¾░ż©</span>"
      ],
      "ethernet": "<span size='10pt'>¾░łĆ</span>",
      "disabled": "<span size='10pt'>¾░żŁ</span>",
      "disconnected": "<span size='10pt'>¾░ż®</span>"
    },
    "tooltip-format-wifi": "{essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "{ifname} ’āü",
    "tooltip-format-disconnected": "Disconnected",
    "on-click": "nm-connection-editor"
  },
  "bluetooth": {
    "format-on": "<span size='10pt'>¾░é»</span>",
    "format-off": "<span size='10pt'>¾░é▓</span>",
    "format-disabled": "<span size='10pt'>¾░é▓</span>",
    "format-connected": "<span size='10pt'>¾░é▒</span>",
    "tooltip-format": "{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_address} | Battery: {device_battery_percentage}%",
    "on-click": "blueman-manager"
  },

  "group/sound": {
    "orientation": "inherit",
    "modules": ["group/sink", "wireplumber#source"]
  },
  "wireplumber": {
    "format": "{icon}",
    "format-muted": "­¤öć",
    "tooltip-format": "{volume}%",
    "format-icons": {
      "default": ["’Ć¦", "’Ć©"]
    },
    "on-click": "pavucontrol"
  },

  "group/power": {
    "orientation": "inherit",
    "modules": ["battery", "power-profiles-daemon"]
  },
  "battery": {
    "format": "{icon}",
    "states": {
      "warning": 20,
      "critical": 10
    },
    "tooltip-format": "{capacity}% - {time} until fully discharged",
    "tooltip-format-charging": "{capacity}% - {time} until fully charged",
    "format-icons": [
      "<span size='10pt'>¾░ü║</span>",
      "<span size='10pt'>¾░ü╗</span>",
      "<span size='10pt'>¾░ü╝</span>",
      "<span size='10pt'>¾░üĮ</span>",
      "<span size='10pt'>¾░üŠ</span>",
      "<span size='10pt'>¾░ü┐</span>",
      "<span size='10pt'>¾░éĆ</span>",
      "<span size='10pt'>¾░éü</span>",
      "<span size='10pt'>¾░éé</span>",
      "<span size='10pt'>¾░ü╣</span>"
    ],
    "format-charging": "<span size='10pt'>¾░éä</span>",
    "format-plugged": "<span size='10pt'>¾░Üź</span>",
    "format-critical": "<span size='10pt'>¾░éā</span>"
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}",
    "tooltip": true,
    "format-icons": {
      "default": "<span size='10pt'>’ā¦</span>",
      "performance": "<span size='10pt'>’ā¦</span>",
      "balanced": "<span size='10pt'>’ēÄ</span>",
      "power-saver": "<span size='10pt'>’ü¼</span>"
    }
  },

  "clock": {
    "format": "{:L%a %d %b %H:%M}",
    "locale": "fr_FR.UTF-8",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "on-click": "gnome-calendar",
    "calendar": {
      "mode"          : "month",
      "mode-mon-col"  : 3,
      "weeks-pos"     : "right",
      "on-scroll"     : 1,
      "format": {
        "months":     "<span color='#ffead3'><b>{}</b></span>",
        "days":       "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
        "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
      }
    },
    "actions":  {
      "on-click-right": "mode",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  }
}
